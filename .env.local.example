# Required — get your free key at https://console.groq.com
GROQ_API_KEY=

# Rate limiting (lookups per IP per 24 hours)
RATE_LIMIT_PER_DAY=20

# Free — sign up at https://numverify.com (real carrier + line type lookup)
NUMVERIFY_API_KEY=

# JSONBin.io — free JSON storage for community reports
# 1. Go to https://jsonbin.io and create a free account
# 2. Create a new bin with content: {"reports":[]}
# 3. Copy the Bin ID from the URL and your Master Key from the dashboard
JSONBIN_BIN_ID=your_bin_id_here
JSONBIN_API_KEY=your_api_key_here

# Required for GetIPIntel threat score — just any email you own
# https://getipintel.net/free-proxy-vpn-tor-detection-api/
GETIPINTEL_EMAIL=your@email.com

# Free — sign up at https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=

